datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model Course {
  id            String         @id @default(uuid())
  title         String
  description   String
  category      String
  thumbnail     String
  teacherId     String
  teacherName   String
  rating        Float          @default(0.0)
  enrolledCount Int            @default(0)
  status        String         @default("pending") // "approved" | "pending" | "rejected"
  feedback      String?
  lectures      Lecture[]
  reviews       Review[]
  questions     Question[]
  progress      UserProgress[]
}

model Lecture {
  id          String   @id @default(uuid())
  title       String
  videoUrl    String
  duration    String
  description String
  order       Int
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model UserProgress {
  id                  String             @id @default(uuid())
  courseId            String
  course              Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userEmail           String
  completedLectures   CompletedLecture[]

  @@unique([courseId, userEmail])
}

model CompletedLecture {
  id             String       @id @default(uuid())
  userProgressId String
  userProgress   UserProgress @relation(fields: [userProgressId], references: [id], onDelete: Cascade)
  lectureId      String

  @@unique([userProgressId, lectureId])
}

model Review {
  id       String @id @default(uuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userName String
  rating   Int
  comment  String
  date     String
}

model Question {
  id       String   @id @default(uuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userName String
  text     String
  date     String
  answers  Answer[]
}

model Answer {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userName   String
  text       String
  date       String
}
